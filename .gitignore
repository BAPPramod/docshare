# --------------------------------------------------
# Git Ignore Rules for DocShare-Mini Project
# --------------------------------------------------

# Node modules
node_modules/

# Build outputs
/backend/dist/
/frontend/dist/
/dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
*.env

# Backend specifics
/backend/prisma/dev.db
/backend/prisma/dev.db-journal
/backend/uploads/*
!/backend/uploads/.gitkeep

# OS files
.DS_Store

# Editor directories
.vscode/
.idea/

# TypeScript
*.tsbuildinfo

# Vite / cache
node_modules/.vite
/.vite

# Coverage
coverage/

# Misc
*.local
